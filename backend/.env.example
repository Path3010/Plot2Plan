# Environment
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Storage
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Geometry
DEFAULT_UNIT=meters
GRID_SNAP=0.15

# Setbacks (meters)
DEFAULT_FRONT_SETBACK=3.0
DEFAULT_BACK_SETBACK=2.0
DEFAULT_SIDE_SETBACK=1.5
